{
  "name": "chess-poc",
  "version": "0.1.0",
  "description": "Standalone BYOA chess proof of concept with Postgres, Ollama, and hybrid retrieval.",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "seed:docs": "node src/scripts/seed-docs.js",
    "test": "node --test"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}